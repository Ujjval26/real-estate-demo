generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          String   @default("user") // admin | agent | user
  status        String   @default("active") // active | banned | pending
  phone         String?
  avatar        String?
  emailVerified DateTime? @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  properties       Property[]
  favourites       Favourite[]
  savedSearches    SavedSearch[]
  messagesSent     Message[]      @relation("MessagesSent")
  messagesReceived Message[]      @relation("MessagesReceived")
  reviewsGiven     Review[]       @relation("ReviewsGiven")
  reviewsReceived  Review[]       @relation("ReviewsReceived")
  statusChanges    StatusChange[]

  @@index([role])
  @@index([status])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Properties
// ---------------------------------------------------------------------------
model Property {
  id             String   @id @default(cuid())
  agentId        String   @map("agent_id")
  title          String
  slug           String   @unique
  description    String
  price          Int
  listingType    String   @default("sale") @map("listing_type") // sale | rent
  propertyType   String   @default("house") @map("property_type")
  pricePeriod    String?  @map("price_period") // pcm | pw
  bedrooms       Int      @default(1)
  bathrooms      Int      @default(1)
  receptionRooms Int      @default(1) @map("reception_rooms")
  size           Int?     // sq ft
  epcRating      String?  @map("epc_rating")
  councilTaxBand String?  @map("council_tax_band")
  tenure         String?
  address        String
  city           String
  postcode       String
  region         String?
  latitude       Float?
  longitude      Float?
  features       String   @default("[]")
  customFeatures String?  @map("custom_features")
  isNewBuild     Boolean  @default(false) @map("is_new_build")
  hasGarden      Boolean  @default(false) @map("has_garden")
  hasParking     Boolean  @default(false) @map("has_parking")
  floorPlanUrl   String?  @map("floor_plan_url")
  status         String   @default("draft")
  // draft | pending | approved | under_offer | sold | let_agreed | archived | withdrawn
  featured       Boolean  @default(false)
  viewCount      Int      @default(0) @map("view_count")
  enquiryCount   Int      @default(0) @map("enquiry_count")
  primaryImage   String?  @map("primary_image")
  publishDate    DateTime? @map("publish_date")
  expiryDate     DateTime? @map("expiry_date")
  soldDate       DateTime? @map("sold_date")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  agent           User            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  images          PropertyImage[]
  favouritedBy    Favourite[]
  messages        Message[]
  viewingRequests ViewingRequest[]
  inquiries       Inquiry[]
  statusChanges   StatusChange[]
  reviews         Review[]

  @@index([listingType])
  @@index([city])
  @@index([status])
  @@index([price])
  @@index([agentId])
  @@index([deletedAt])
  @@index([postcode])
  @@map("properties")
}

// ---------------------------------------------------------------------------
// Property Images
// ---------------------------------------------------------------------------
model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  imageUrl   String   @map("image_url")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

// ---------------------------------------------------------------------------
// Favourites
// ---------------------------------------------------------------------------
model Favourite {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  propertyId String   @map("property_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@map("favourites")
}

// ---------------------------------------------------------------------------
// Saved Searches
// ---------------------------------------------------------------------------
model SavedSearch {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  name               String?
  searchCriteria     String   @default("{}") @map("search_criteria")
  emailAlertsEnabled Boolean  @default(false) @map("email_alerts_enabled")
  lastAlertedAt      DateTime? @map("last_alerted_at")
  createdAt          DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_searches")
}

// ---------------------------------------------------------------------------
// Messages
// ---------------------------------------------------------------------------
model Message {
  id          String   @id @default(cuid())
  senderId    String   @map("sender_id")
  receiverId  String   @map("receiver_id")
  propertyId  String?  @map("property_id")
  subject     String?
  messageText String   @map("message_text")
  readStatus  Boolean  @default(false) @map("read_status")
  createdAt   DateTime @default(now()) @map("created_at")

  sender   User      @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User      @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([senderId])
  @@index([receiverId])
  @@index([propertyId])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// Viewing Requests
// ---------------------------------------------------------------------------
model ViewingRequest {
  id            String    @id @default(cuid())
  propertyId    String    @map("property_id")
  name          String
  email         String
  phone         String?
  preferredDate DateTime   @map("preferred_date")
  preferredTime String?    @map("preferred_time")
  notes         String?
  status        String    @default("pending")
  // pending | confirmed | completed | cancelled | no_show
  confirmedBy   String?   @map("confirmed_by")
  confirmedAt   DateTime? @map("confirmed_at")
  completedAt   DateTime? @map("completed_at")
  feedback      String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([status])
  @@index([email])
  @@map("viewing_requests")
}

// ---------------------------------------------------------------------------
// Reviews
// ---------------------------------------------------------------------------
model Review {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  agentId    String   @map("agent_id")
  userId     String   @map("user_id")
  rating     Int
  comment    String?
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agent    User     @relation("ReviewsReceived", fields: [agentId], references: [id], onDelete: Cascade)
  user     User     @relation("ReviewsGiven", fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([agentId])
  @@index([approved])
  @@map("reviews")
}

// ---------------------------------------------------------------------------
// Status Change Audit Trail
// ---------------------------------------------------------------------------
model StatusChange {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  oldStatus  String   @map("old_status")
  newStatus  String   @map("new_status")
  changedBy  String   @map("changed_by")
  reason     String?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  changedByUser User     @relation(fields: [changedBy], references: [id])

  @@index([propertyId])
  @@index([createdAt])
  @@map("status_changes")
}

// ---------------------------------------------------------------------------
// Locations
// ---------------------------------------------------------------------------
model Location {
  id            String   @id @default(cuid())
  name          String
  postcode      String
  region        String
  type          String   @default("city")
  propertyCount Int      @default(0) @map("property_count")
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@index([postcode])
  @@map("locations")
}

// ---------------------------------------------------------------------------
// Inquiries / Leads
// ---------------------------------------------------------------------------
model Inquiry {
  id         String   @id @default(cuid())
  propertyId String?  @map("property_id")
  name       String
  email      String
  phone      String?
  subject    String?
  message    String
  status     String   @default("new") // new | read | replied | resolved
  source     String   @default("website") // website | phone | email
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
  @@map("inquiries")
}

// ---------------------------------------------------------------------------
// Site Settings
// ---------------------------------------------------------------------------
model SiteSetting {
  key   String @id
  value String

  @@map("site_settings")
}
